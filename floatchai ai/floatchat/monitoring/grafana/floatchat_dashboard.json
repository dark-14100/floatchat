          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (handler, le) (rate(http_request_duration_seconds_bucket{handler!~\"/metrics|/health|/api/v1/health\"}[5m])))",
          "legendFormat": "{{handler}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (handler, le) (rate(http_request_duration_seconds_bucket{handler!~\"/metrics|/health|/api/v1/health\"}[5m])))",
          "legendFormat": "{{handler}} p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (handler, le) (rate(http_request_duration_seconds_bucket{handler!~\"/metrics|/health|/api/v1/health\"}[5m])))",
          "legendFormat": "{{handler}} p99",
          "refId": "C"
        }
      ],
      "title": "Request Latency p50/p95/p99 by Endpoint",
      "type": "timeseries"
